# Copy to .env and fill in. Users can browse without login by default.

# Auth: set to true to show login screen first and require sign-in. Default: false (browse without login).
# EXPO_PUBLIC_ENABLE_AUTH=true

# Optional: default admin emails (comma-separated). These users get Admin access when they sign in.
# EXPO_PUBLIC_ADMIN_EMAILS=admin@yourdomain.com,coach@yourdomain.com

# Supabase (required when auth is on)
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
