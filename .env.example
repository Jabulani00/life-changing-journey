# Copy to .env (do not commit .env). Restart Expo after changes.

# Calendly Personal Access Token (Bearer) — rotate if exposed
EXPO_PUBLIC_CALENDLY_TOKEN=

# After calling GET https://api.calendly.com/users/me, paste resource.uri here (optional)
EXPO_PUBLIC_CALENDLY_USER_URI=

# Public scheduling page URL (embed link), e.g. https://calendly.com/your-handle/consultation
EXPO_PUBLIC_CALENDLY_EMBED_URL=

# Comma-separated admin emails (optional; also uses config/admins in Firestore)
EXPO_PUBLIC_ADMIN_EMAILS=
